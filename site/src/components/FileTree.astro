---
import type { CollectionEntry } from 'astro:content';
import { originalRelPath, slugifyPath } from '../lib/project-paths';

interface Props {
  files: Array<CollectionEntry<'projectFiles'> | CollectionEntry<'paperFiles'>>;
  originalBasePath: string; // e.g. "projects/workflow_state" (preserves underscores/case)
  depth?: number;
}

const { files, originalBasePath, depth = 0 } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface FolderEntry {
  name: string;
  originalPath: string;
  children: Array<CollectionEntry<'projectFiles'> | CollectionEntry<'paperFiles'>>;
}
interface FileEntry {
  entry: CollectionEntry<'projectFiles'> | CollectionEntry<'paperFiles'>;
  name: string;
}

const folders = new Map<string, FolderEntry>();
const fileEntries: FileEntry[] = [];

const prefix = originalBasePath + '/';
for (const entry of files) {
  const orig = originalRelPath(entry);
  if (!orig.startsWith(prefix)) continue;
  const rel = orig.slice(prefix.length);
  const parts = rel.split('/');
  if (parts.length === 1) {
    fileEntries.push({ entry, name: parts[0] });
  } else {
    const folderName = parts[0];
    if (!folders.has(folderName)) {
      folders.set(folderName, {
        name: folderName,
        originalPath: originalBasePath + '/' + folderName,
        children: [],
      });
    }
    folders.get(folderName)!.children.push(entry);
  }
}

const sortedFolders = [...folders.values()].sort((a, b) =>
  a.name.localeCompare(b.name, undefined, { sensitivity: 'base' })
);
const sortedFiles = fileEntries.sort((a, b) =>
  a.name.localeCompare(b.name, undefined, { sensitivity: 'base' })
);
---

<ul class="file-tree list-none p-0 m-0">
  {sortedFolders.map(folder => (
    <li class="my-0.5">
      <details open={depth === 0}>
        <summary class="cursor-pointer select-none py-0.5 px-1 rounded hover:bg-(--color-surface-hover) flex items-center gap-1.5">
          <span class="text-(--color-text-muted)" aria-hidden="true">&#128193;</span>
          <a
            href={`${base}/${slugifyPath(folder.originalPath)}/`}
            class="text-(--color-link) hover:underline font-medium no-underline"
          >
            {folder.name}
          </a>
          <span class="text-xs text-(--color-text-muted) ml-1">({folder.children.length})</span>
        </summary>
        <div class="ml-5 border-l border-(--color-border) pl-3 mt-0.5">
          <Astro.self files={folder.children} originalBasePath={folder.originalPath} depth={depth + 1} />
        </div>
      </details>
    </li>
  ))}
  {sortedFiles.map(({ entry, name }) => (
    <li class="my-0.5 py-0.5 px-1 rounded hover:bg-(--color-surface-hover) flex items-center gap-1.5">
      <span class="text-(--color-text-muted)" aria-hidden="true">&#128196;</span>
      <a
        href={`${base}/${entry.id}/`}
        class="text-(--color-link) hover:underline no-underline"
      >
        {name}
      </a>
    </li>
  ))}
</ul>
