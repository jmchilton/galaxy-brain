---
import { getCollection } from 'astro:content';
import NoteView from '../components/NoteView.astro';

export async function getStaticPaths() {
  const entries = await getCollection('vault');
  // Papers are served by dedicated routes (papers/[paper]/index = manuscript
  // front door, papers/[paper]/workspace = drafting dashboard).
  return entries
    .filter(entry => entry.data.type !== 'paper')
    .map(entry => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
---
<NoteView entry={entry} />
