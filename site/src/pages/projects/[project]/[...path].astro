---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import FileTree from '../../../components/FileTree.astro';
import { originalRelPath } from '../../../lib/project-paths';

function titleize(s: string): string {
  return s.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
}

export async function getStaticPaths() {
  const entries = await getCollection('projectFiles');

  // Group entries by project
  const projectEntries = new Map<string, CollectionEntry<'projectFiles'>[]>();
  for (const entry of entries) {
    const parts = entry.id.split('/');
    const project = parts[1];
    if (!projectEntries.has(project)) projectEntries.set(project, []);
    projectEntries.get(project)!.push(entry);
  }

  const paths: any[] = [];

  for (const [project, projFiles] of projectEntries) {
    // File paths
    for (const entry of projFiles) {
      const relPath = entry.id.split('/').slice(2).join('/');
      paths.push({
        params: { project, path: relPath },
        props: { entry, isFolder: false },
      });
    }

    // Folder paths — extract unique directory prefixes (slugified, used in URL)
    const folderPaths = new Set<string>();
    for (const entry of projFiles) {
      const parts = entry.id.split('/').slice(2); // after projects/<name>
      for (let i = 1; i < parts.length; i++) {
        folderPaths.add(parts.slice(0, i).join('/'));
      }
    }
    for (const folderPath of folderPaths) {
      paths.push({
        params: { project, path: folderPath },
        props: { isFolder: true, folderPath: `projects/${project}/${folderPath}` },
      });
    }
  }

  return paths;
}

const { entry, isFolder, folderPath } = Astro.props;
const { project, path: routePath } = Astro.params;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Look up parent project (vault entry)
const allNotes = await getCollection('vault');
const projectSlug = `projects/${project}`;
const parentProject = allNotes.find(n => n.id === projectSlug);
const projectTitle = parentProject?.data.title || titleize(project!);

// Original directory of the project, e.g. "projects/workflow_state"
const projectOriginalDir = parentProject
  ? originalRelPath(parentProject).replace(/\/index$/, '')
  : projectSlug;

// For folders we need the children to derive the original folder names.
let folderFiles: CollectionEntry<'projectFiles'>[] = [];
let originalFolderPath = '';
if (isFolder) {
  const allProjectFiles = await getCollection('projectFiles');
  const prefix = folderPath + '/';
  folderFiles = allProjectFiles
    .filter(f => f.id.startsWith(prefix))
    .sort((a, b) => a.id.localeCompare(b.id));
  // Reconstruct the original folder path from a child file's filePath.
  // depth = 2 (projects/<project>) + number of folder segments below project.
  const folderDepth = 2 + routePath!.split('/').length;
  if (folderFiles.length > 0) {
    originalFolderPath = originalRelPath(folderFiles[0])
      .split('/')
      .slice(0, folderDepth)
      .join('/');
  }
}

// Build breadcrumb segments using original names where possible.
interface Breadcrumb { label: string; href?: string }
const breadcrumbs: Breadcrumb[] = [
  { label: 'Home', href: `${base}/` },
  { label: projectTitle, href: `${base}/${projectSlug}/` },
];

// Page title and intermediate folder labels: prefer original names.
let pageTitle: string;
const slugSegments = routePath!.split('/');

if (!isFolder && entry) {
  const fileOrig = originalRelPath(entry);
  const fileParts = fileOrig.split('/'); // projects/<orig>/.../<file>
  // Original folder segments live between the project dir and the filename.
  const projectDirParts = projectOriginalDir.split('/').length;
  const intermediateFolders = fileParts.slice(projectDirParts, -1);
  const fileName = fileParts[fileParts.length - 1];

  for (let i = 0; i < intermediateFolders.length; i++) {
    const folderSlug = slugSegments.slice(0, i + 1).join('/');
    breadcrumbs.push({
      label: intermediateFolders[i],
      href: `${base}/projects/${project}/${folderSlug}/`,
    });
  }
  pageTitle = fileName;
} else {
  // Folder route: original folder names from originalFolderPath
  const projectDirParts = projectOriginalDir.split('/').length;
  const folderParts = originalFolderPath
    ? originalFolderPath.split('/').slice(projectDirParts)
    : slugSegments; // fallback if no children (shouldn't happen)

  for (let i = 0; i < folderParts.length - 1; i++) {
    const folderSlug = slugSegments.slice(0, i + 1).join('/');
    breadcrumbs.push({
      label: folderParts[i],
      href: `${base}/projects/${project}/${folderSlug}/`,
    });
  }
  pageTitle = folderParts[folderParts.length - 1] || titleize(slugSegments[slugSegments.length - 1]);
}

breadcrumbs.push({ label: pageTitle });

// Render content for file entries
let Content: any = null;
if (!isFolder && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}
---
<Base title={pageTitle} pageTitle={pageTitle}>
  <nav class="mb-4 text-sm text-(--color-text-secondary)">
    {breadcrumbs.map((bc, i) => (
      <>
        {i > 0 && <span class="mx-1">&rsaquo;</span>}
        {bc.href
          ? <a href={bc.href} class="text-(--color-link) hover:underline">{bc.label}</a>
          : <span>{bc.label}</span>}
      </>
    ))}
  </nav>

  <h1 class="mb-4 text-2xl font-bold">{pageTitle}</h1>

  {isFolder ? (
    <FileTree files={folderFiles} originalBasePath={originalFolderPath} />
  ) : (
    <article class="prose prose-slate max-w-none dark:prose-invert" data-pagefind-body>
      {Content && <Content />}
    </article>
  )}
</Base>
